{
  "JwtSettings": {
    "Issuer": "AUTH-service",
    "Audience": "platform-services",
    "Key": "qsjhdhqsdhhuzhdhdgeudgudsgv,nfkuhzgezfuvjhknfjhsdbgvsqjhvvudsdfhvfuzbhjdqsjbddahugfu"
  },

  "AllowedOrigins": [
    "https://business-pulse-two.vercel.app",
    "*"
  ],

"ReverseProxy": {
    "Routes": {

      "auth-public": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "false" },
          { "X-Forwarded": "Set" }
        ]
      },

      "user-me": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "false" },
          { "X-Forwarded": "Set" }
        ]
      },

      "admin-users": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "admin-only",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "false" },
          { "X-Forwarded": "Set" }
        ]
      },

      "mdx-clients": {
        "ClusterId": "mdx-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/clients/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "false" },
          { "X-Forwarded": "Set" }
        ]
      },

      "ai-ask": {
        "ClusterId": "ai-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/ask",
          "Methods": ["POST"]
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "false" },
          { "X-Forwarded": "Set" }
        ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://51.68.44.166:8084/" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "mdx-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://51.68.44.166:8080/" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "ai-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://51.68.44.166:8000/" }
        }
      }
    }
  }
}